#define helper function to ask yes
def ask_yes(value):
    value = input(value).lower()
    if value == "yes":
        return True
    else:
        return False

#function to calculate initial horizontal velocity
def calcinitialhorizontalvelocity():
    #ask user if they have the initialy velocity
    initialvelocity = str(input("Do you have the initial velocity?"))
    #ask user if they have the angle of the initial motion
    angle = str(input("Do you have the angle of the initial motion?"))
    #if they have both, calculate the initial horizontal velocity
    if ask_yes(initialvelocity) and ask_yes(angle):
        #ask for values for initial velocity and angle
        initialvelocity = float(input("What is the initial velocity in m/s?"))
        angle = float(input("What is the angle of the initial motion in degrees?"))
        #use trigonometry to calculate the initial horizontal velocity
        initialhorizontalvelocity = initialvelocity * math.cos(math.radians(angle))
        return initialhorizontalvelocity #return the initial horizontal velocity
    else:
        #asks if they have the initial vertical velocity
        initialverticalvelocity = str(input("Do you have the initial vertical velocity?"))
        if ask_yes(initialverticalvelocity) and ask_yes(angle):
            #ask for value of initial vertical velocity
            initialverticalvelocity = float(input("What is the initial vertical velocity in m/s?"))
            angle = float(input("What is the angle of the initial motion in degrees?"))
            #use trigonometry to calculate the initial horizontal velocity
            initialhorizontalvelocity = initialverticalvelocity / math.tan(math.radians(angle))
            return initialhorizontalvelocity #return the initial horizontal velocity
        elif ask_yes(initialverticalvelocity) and ask_yes(initialvelocity):
            #ask for value of initial vertical velocity
            initialverticalvelocity = float(input("What is the initial vertical velocity in m/s?"))
            initialvelocity = float(input("What is the initial velocity in m/s?"))
            #use pythagoras to calculate the initial horizontal velocity
            initialhorizontalvelocity = math.sqrt(initialvelocity**2 - initialverticalvelocity**2)
            return initialhorizontalvelocity #return the initial horizontal velocity

#function to calculate initial vertical velocity
