#function to calculate angle of initial motion   
def calcangle():
    #ask user if they have the initial horizontal velocity
    initialhorizontalvelocity = str(input("Do you have the initial horizontal velocity?"))
    #ask user if they have the initial vertical velocity
    initialverticalvelocity = str(input("Do you have the initial vertical velocity?"))
    #if they have both, calculate the angle of the initial motion
    if ask_yes(initialhorizontalvelocity) and ask_yes(initialverticalvelocity):
        #ask for values for initial horizontal velocity and initial vertical velocity
        initialhorizontalvelocity = float(input("What is the initial horizontal velocity in m/s?"))
        initialverticalvelocity = float(input("What is the initial vertical velocity in m/s?"))
        #use trigonometry to calculate the angle of the initial motion
        angle = math.degrees(math.atan(initialverticalvelocity / initialhorizontalvelocity))
        return angle #return the angle of the initial motion
    else:
        #asks if they have the initial velocity
        initialvelocity = str(input("Do you have the initial velocity?"))
        if ask_yes(initialvelocity) and ask_yes(initialhorizontalvelocity):
            #ask for value of initial velocity
            initialvelocity = float(input("What is the initial velocity in m/s?"))
            initialhorizontalvelocity = float(input("What is the initial horizontal velocity in m/s?"))
            #use trigonometry to calculate the angle of the initial motion
            angle = math.degrees(math.acos(initialhorizontalvelocity / initialvelocity))
            return angle #return the angle of the initial motion
        elif ask_yes(initialvelocity) and ask_yes(initialverticalvelocity):
            #ask for value of initial velocity
            initialvelocity = float(input("What is the initial velocity in m/s?"))
            initialverticalvelocity = float(input("What is the initial vertical velocity in m/s?"))
            #use trigonometry to calculate the angle of the initial motion
            angle = math.degrees(math.asin(initialverticalvelocity / initialvelocity))
            return angle #return the angle of the initial motion